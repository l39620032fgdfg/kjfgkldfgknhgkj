local function getGitSoundId(GithubSoundPath, AssetName)
  local Url = GithubSoundPath
  writefile(AssetName..".mp3", game:HttpGet(Url)) 
  return getcustomasset(AssetName..".mp3")
end

local f = getGitSoundId("https://raw.githubusercontent.com/ipadys/core/refs/heads/main/audio_2025-12-04_15-22-47.mp3", "po")

local dd = Instance.new("Sound")
dd.Parent = workspace
dd.SoundId = f
dd.Volume = 10
dd.Looped = true
dd:Play()

local function getGitImageId(GithubSoundPath, AssetName)
